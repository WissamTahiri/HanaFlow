# ============================================================
#  HanaFlow — Backend Environment Variables
#  Copier ce fichier en .env et remplir les valeurs réelles
#  NE JAMAIS committer le fichier .env dans git
# ============================================================

# --- Serveur ---
NODE_ENV=development
# Valeurs possibles : development | production
PORT=5000

# --- Base de données PostgreSQL ---
# Neon (production) : récupérer l'URL dans le dashboard Neon
# Format : postgresql://user:password@host/dbname?sslmode=verify-full
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=verify-full

# --- JWT Authentication ---
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-minimum-64-characters-long-random-string

# Durée de vie du token d'accès
JWT_EXPIRES_IN=1h

# Secret pour les refresh tokens (doit être DIFFÉRENT de JWT_SECRET)
# Générer avec la même commande ci-dessus
JWT_REFRESH_SECRET=change-me-another-64-characters-long-random-string

# Durée de vie du refresh token
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
# Origines autorisées, séparées par des virgules (sans espaces)
# Développement local : http://localhost:5173
# Production Vercel : ajouter l'URL Vercel ex. https://hanaflow.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
# 15 tentatives par fenêtre de 15 minutes
RATE_LIMIT_MAX=15
