# ============================================================
#  HanaFlow — Frontend Environment Variables
#  Copier ce fichier en .env et remplir les valeurs réelles
#  NE JAMAIS committer le fichier .env dans git
# ============================================================

# URL de l'API backend
# Développement local : http://localhost:5000
# Production Render : https://hanaflow-api.onrender.com (remplacer par votre URL)
VITE_API_URL=http://localhost:5000

# --- Sentry (monitoring des erreurs frontend en production) ---
# Récupérer le DSN dans : https://sentry.io → Ton projet → Settings → Client Keys (DSN)
# Laisser vide en développement — Sentry ne s'initialise qu'en production (PROD=true)
VITE_SENTRY_DSN=
