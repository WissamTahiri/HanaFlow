generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(100)
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  role            String    @default("student") @db.VarChar(20)
  isPro           Boolean   @default(false) @map("is_pro")
  isSuspended     Boolean   @default(false) @map("is_suspended")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  // Secret TOTP : stocké chiffré au format AES-GCM (nonce:cipher:tag, hex) si
  // TOTP_ENCRYPTION_KEY est défini. Les secrets historiques en clair restent
  // lisibles (auto-upgrade au prochain accès). Voir src/lib/totpCrypto.ts.
  totpSecret      String?   @map("totp_secret") @db.VarChar(512)
  totpEnabled     Boolean   @default(false) @map("totp_enabled")
  totpEnabledAt   DateTime? @map("totp_enabled_at") @db.Timestamptz
  // Anti-replay : dernier "step" TOTP (epoch / 30s) consommé. Refuse la
  // réutilisation du même code dans la fenêtre de tolérance.
  totpLastStep    Int?      @map("totp_last_step")
  // Hashes SHA-256 des codes de récupération à usage unique (JSON array).
  totpBackupCodes Json?     @map("totp_backup_codes")
  // Date du dernier changement de mot de passe — sert à invalider les access
  // tokens encore vivants émis avant ce changement (cf serverAuth/apiHelpers).
  pwdChangedAt    DateTime? @map("pwd_changed_at") @db.Timestamptz
  // Vérification d'email à l'inscription. Si null, l'utilisateur n'a pas
  // confirmé son email (accès partiel ou bloqué selon la politique).
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz

  refreshTokens RefreshToken[]
  progress      UserProgress[]
  passwordResetTokens PasswordResetToken[]
  emailVerifications  EmailVerificationToken[]
  certificates  CompletionCertificate[]
  feedback      Feedback[]
  npsResponses  NPSResponse[]

  @@map("users")
}

/**
 * Feedback libre laissé via le widget flottant.
 * Peut être anonyme (userId null) — dans ce cas on garde l'IP pour le
 * rate-limit anti-spam et la modération.
 */
model Feedback {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  /** URL où le user était quand il a soumis (ex: /modules-sap/fi). */
  context     String?  @db.VarChar(200)
  /** Ce qui marche bien (peut être vide). */
  goodWhat    String?  @map("good_what") @db.Text
  /** Ce qui manque / à améliorer (peut être vide). */
  improveWhat String?  @map("improve_what") @db.Text
  /** Statut de traitement par l'admin. */
  status      String   @default("new") @db.VarChar(20)
  ipAddress   String?  @map("ip_address") @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  /** Optionnel : email pour relancer le user si feedback anonyme intéressant. */
  contactEmail String? @map("contact_email") @db.VarChar(255)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
  @@map("feedback")
}

/**
 * Réponse au NPS (Net Promoter Score). Affiché in-app après J+7 d'usage,
 * une fois tous les 90 jours max (un user ne reçoit pas le prompt en boucle).
 */
model NPSResponse {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  /** Score sur 11 (0-10). */
  score     Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
  @@map("nps_responses")
}

/**
 * Témoignage public (gérés par l'admin). Affichés sur la home et la
 * pricing page comme social proof.
 */
model Testimonial {
  id               Int      @id @default(autoincrement())
  authorName       String   @map("author_name") @db.VarChar(120)
  /** Rôle court (ex: "Consultant SAP FI junior"). */
  authorRole       String?  @map("author_role") @db.VarChar(120)
  authorCompany    String?  @map("author_company") @db.VarChar(120)
  authorPhotoUrl   String?  @map("author_photo_url") @db.Text
  authorLinkedInUrl String? @map("author_linkedin_url") @db.Text
  quote            String   @db.Text
  /** 1-5 étoiles, optionnel. */
  rating           Int?
  isPublished      Boolean  @default(true) @map("is_published")
  /** À mettre en hero / featured (1-2 max). */
  isFeatured       Boolean  @default(false) @map("is_featured")
  /** Ordre d'affichage manuel (ascending). */
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([isPublished, sortOrder])
  @@map("testimonials")
}

model CompletionCertificate {
  // ID public (cuid) : utilisé dans l'URL de vérification.
  // Pas d'autoincrement → on ne révèle pas le volume de certifs émis.
  id            String   @id @default(cuid())
  userId        Int      @map("user_id")
  moduleCode    String   @map("module_code") @db.VarChar(10)
  /** Module label snapshot (au cas où le catalogue change après émission). */
  moduleLabel   String   @map("module_label") @db.VarChar(120)
  /** Code certif officiel SAP snapshot (ex: C_TS4FI_2601). */
  certCode      String?  @map("cert_code") @db.VarChar(40)
  /** Nom complet du candidat au moment de l'émission. */
  candidateName String   @map("candidate_name") @db.VarChar(120)
  /** Score obtenu sur 100. */
  examScore     Int      @map("exam_score")
  /** Nombre de questions du simulateur passé. */
  examQuestions Int      @map("exam_questions")
  issuedAt      DateTime @default(now()) @map("issued_at") @db.Timestamptz
  /** Révoqué par admin (fraude, plainte) — n'affiche plus comme valide. */
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz
  revokedReason String?   @map("revoked_reason") @db.VarChar(255)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 1 certificat par user × module : repasser le simulateur ne réémet pas
  // un nouveau cert mais update celui existant (meilleur score conservé).
  @@unique([userId, moduleCode])
  @@index([userId])
  @@index([issuedAt])
  @@map("completion_certificates")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  // SHA-256 du token : le clair n'est jamais persisté
  tokenHash String   @unique @map("token_hash") @db.VarChar(128)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  ipAddress String?  @map("ip_address") @db.VarChar(64)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(128)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PromoCode {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(50)
  description String?   @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  usageLimit  Int?      @map("usage_limit")
  usageCount  Int       @default(0) @map("usage_count")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz

  @@map("promo_codes")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model UserProgress {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  module    String   @db.VarChar(20)
  visitedAt DateTime @default(now()) @map("visited_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
  @@map("user_progress")
}

model AdminAuditLog {
  id           Int      @id @default(autoincrement())
  actorId      Int?     @map("actor_id")
  actorEmail   String   @map("actor_email") @db.VarChar(255)
  action       String   @db.VarChar(64)
  targetType   String?  @map("target_type") @db.VarChar(32)
  targetId     String?  @map("target_id") @db.VarChar(64)
  metadata     Json?
  ipAddress    String?  @map("ip_address") @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
  @@map("admin_audit_log")
}

model SiteSetting {
  key       String   @id @db.VarChar(64)
  value     String   @db.Text
  category  String   @default("general") @db.VarChar(32)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy String?  @map("updated_by") @db.VarChar(255)

  @@map("site_settings")
}
