# ─── Base de données (Neon PostgreSQL) ────────────────────────────────
# DATABASE_URL : URL poolée (utilisée par l'app au runtime)
# DIRECT_URL   : URL directe (utilisée par Prisma pour les migrations)
# Récupérables sur https://console.neon.tech → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── JWT secrets ──────────────────────────────────────────────────────
# Générer chaque secret avec :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Les deux DOIVENT être différents.
JWT_SECRET="changeme_generate_64_random_hex_chars"
JWT_REFRESH_SECRET="changeme_generate_different_64_random_hex_chars"

# Durées (optionnel — valeurs par défaut indiquées)
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Chiffrement des secrets TOTP (2FA) ───────────────────────────────
# 32 bytes en hex (64 chars). Si absent, les secrets TOTP sont stockés
# en CLAIR : à activer impérativement en prod.
# Générer avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=""

# ─── Rate-limiting distribué (Upstash Redis) ──────────────────────────
# Sans ces vars, le rate-limit en mémoire est inefficace sur Vercel
# serverless (chaque fonction Lambda a sa propre Map). À configurer
# impérativement en prod.
# Compte gratuit : https://upstash.com → Create Redis Database
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── URL publique de l'app ────────────────────────────────────────────
# Utilisée pour sitemap.xml, OG tags, schema.org, liens emails
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Email (Resend) — optionnel ───────────────────────────────────────
# Si absent, les emails s'affichent en console (utile en dev).
# Compte gratuit : https://resend.com
RESEND_API_KEY=""
RESEND_FROM_EMAIL="HanaFlow <noreply@hanaflow.app>"

# Email recevant les notifications admin (nouveaux inscrits, etc.)
ADMIN_NOTIFICATION_EMAIL=""
