{
  "name": "hanaflow-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build --webpack",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "start": "next start",
    "lint": "eslint",
    "fix:natives": "bash scripts/install-darwin-arm64-natives.sh",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "prepare": "node -e \"process.env.CI || require('child_process').execSync('cd .. && node hanaflow-next/node_modules/husky/bin.js hanaflow-next/.husky', {stdio:'inherit'})\""
  },
  "lint-staged": {
    "hanaflow-next/src/**/*.{ts,tsx}": [
      "bash -c 'cd hanaflow-next && node node_modules/eslint/bin/eslint.js --max-warnings=0 --no-warn-ignored'"
    ]
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@prisma/client": "^6.19.2",
    "@react-pdf/renderer": "^4.3.2",
    "@types/cookie": "^0.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "argon2": "^0.44.0",
    "cookie": "^1.1.1",
    "date-fns": "^4.1.0",
    "groq-sdk": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "otplib": "^13.4.0",
    "prisma": "^6.19.2",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "resend": "^6.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@serwist/next": "^9.5.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "serwist": "^9.5.11",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
